{
  "name": "com.kikx.florix",
  "title": "Florix",
  "author": "luvbyte",
  "version": "0.1.0",
  "kikx_version": "0.2.0",

  "include": ["public", "tasks", "www"],

  "iframe": {
    "allowfullscreen": true,
    "allow": ["screen-wake-lock", "clipboard-read", "clipboard-write"],
    "sandbox": ["allow-scripts"]
  },
  "system": {
    "access": ["funcx", "notify", "alert"]
  },
  "modules": {
    "tasks": {
      "shell": true
    }
  },

  "theme": "transparent"
}
